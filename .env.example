# -----------------------------------------------------------------------------
# Service Credentials
# -----------------------------------------------------------------------------

# Grafana Admin User Password
SERVICE_PASSWORD_GRAFANA=change-this-to-a-strong-password

# PostgreSQL Credentials (used by Grafana)
POSTGRES_DB=grafana
SERVICE_USER_POSTGRES=grafana
SERVICE_PASSWORD_POSTGRES=change-this-to-a-strong-password

# Basic Auth Credentials (Traefik middleware)
PROMETHEUS_BASIC_AUTH=your-htpasswd-string-here
LOKI_BASIC_AUTH=your-htpasswd-string-here
ALLOY_BASIC_AUTH=your-htpasswd-string-here

# -----------------------------------------------------------------------------
# Grafana SMTP Configuration
# -----------------------------------------------------------------------------

GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.example.com:587
GF_SMTP_USER=your-smtp-username
GF_SMTP_PASSWORD=your-smtp-password
GF_SMTP_FROM_ADDRESS=grafana@example.com
GF_SMTP_FROM_NAME=Grafana
GF_SMTP_SKIP_VERIFY=false
GF_SMTP_STARTTLS_POLICY=OpportunisticStartTLS

# -----------------------------------------------------------------------------
# Google Cloud Storage (GCS) Configuration
# -----------------------------------------------------------------------------

# GCS Bucket Name for Loki (logs) and Tempo (traces)
GCS_BUCKET_NAME=your-gcs-bucket-name

# Google Cloud Service Account JSON (base64-encoded)
# Encode your service account key file with:
#   cat your-service-account.json | base64 | tr -d '\n'
# Then paste the result here.
GCS_SERVICE_ACCOUNT_B64=your-base64-encoded-service-account-json
